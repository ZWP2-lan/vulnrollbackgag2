    end
end)

-- Dragging support (robust)
do
    local dragging = false
    local dragInput = nil
    local dragStart = Vector2.new()
    local startPos = container.Position

    local function update(inputPos)
        local delta = inputPos - dragStart
        local newX = startPos.X.Offset + delta.X
        local newY = startPos.Y.Offset + delta.Y
        container.Position = UDim2.new(startPos.X.Scale, newX, startPos.Y.Scale, newY)
    end

    titleBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragInput = input
            dragStart = input.Position
            startPos = container.Position
        end
    end)

    titleBar.InputEnded:Connect(function(input)
        if input == dragInput then
            dragging = false
            dragInput = nil
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if dragging and input == dragInput and input.Position then
            update(input.Position)
        end
    end)

    -- Fallback: if the input doesn't generate InputChanged events (very rare), also update on RenderStepped
    RunService.RenderStepped:Connect(function()
        if dragging and dragInput and dragInput.Position then
            update(dragInput.Position)
        end
    end)
end

-- Entrance animation: slide up from 12px offset
do
    local startPos = container.Position
    local offsetPos = UDim2.new(startPos.X.Scale, startPos.X.Offset, startPos.Y.Scale, startPos.Y.Offset + 12)
    container.Position = offsetPos
    container.BackgroundTransparency = 1
    -- fade in background
    TweenService:Create(container, TweenInfo.new(0.36, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {BackgroundTransparency = 0}):Play()
    -- slide to original
    TweenService:Create(container, TweenInfo.new(0.36, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Position = startPos}):Play()
end

