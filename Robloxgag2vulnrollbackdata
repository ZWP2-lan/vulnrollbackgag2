-- Toggle animation function
local function animateToggle(toggle, enabled)
    local container = toggle.SwitchContainer
    local inner = toggle.Inner
    local stateLabel = toggle.StateLabel

    local targetPos = enabled and UDim2.new(1, -30, 0, 0) or UDim2.new(0, 2, 0, 0)
    local tInner = TweenService:Create(inner, TweenInfo.new(0.22, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
        Position = targetPos,
        BackgroundColor3 = enabled and Color3.fromRGB(90, 200, 170) or Color3.fromRGB(240,240,245),
    })
    tInner:Play()

    TweenService:Create(stateLabel, TweenInfo.new(0.22), {
        TextColor3 = enabled and Color3.fromRGB(150,230,200) or Color3.fromRGB(160,165,170),
    }):Play()

    TweenService:Create(container, TweenInfo.new(0.22), {
        BackgroundColor3 = enabled and Color3.fromRGB(36, 45, 54) or Color3.fromRGB(62, 67, 75)
    }):Play()

    stateLabel.Text = enabled and "ON" or "OFF"
end

-- Button bounce
local function buttonBounce(btn)
    local orig = btn.BackgroundColor3
    local darker = orig:Lerp(Color3.new(0,0,0), 0.08)
    local t1 = TweenService:Create(btn, TweenInfo.new(0.08, Enum.EasingStyle.Quad), {BackgroundColor3 = darker})
    local t2 = TweenService:Create(btn, TweenInfo.new(0.12, Enum.EasingStyle.Quad), {BackgroundColor3 = orig})
    t1:Play()
    t1.Completed:Wait()
    t2:Play()
end

-- State variables & debounce
local rollbackEnabled = false
local cancelEnabled = false
local actionDebounce = false

-- Safe click handler wrapper
local function doOnceAsync(fn)
    if actionDebounce then return end
    actionDebounce = true
    local suc, err = pcall(fn)
    if not suc then warn("Action error:", err) end
    wait(0.22)
    actionDebounce = false
end

-- Wire toggles
local function wireToggle(toggleTable, onPayload, offPayload, stateRef)
    local toggleArea = toggleTable.ToggleArea
    toggleArea.MouseButton1Click:Connect(function()
        doOnceAsync(function()
            toggleTable.Enabled = not toggleTable.Enabled
            if toggleTable == rollbackToggle then rollbackEnabled = toggleTable.Enabled end
            if toggleTable == cancelToggle then cancelEnabled = toggleTable.Enabled end
            animateToggle(toggleTable, toggleTable.Enabled)
            if toggleTable.Enabled then
                safeFire(REMOTE_ID, onPayload)
            else
                safeFire(REMOTE_ID, offPayload)
            end
        end)
    end)
end

wireToggle(rollbackToggle, ROLLBACK_ON_PAYLOAD, ROLLBACK_OFF_PAYLOAD, "rollbackEnabled")
wireToggle(cancelToggle, CANCEL_ON_PAYLOAD, CANCEL_OFF_PAYLOAD, "cancelEnabled")

